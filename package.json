    "react-dom": "19.2.6",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "json-server": "^1.0.0-beta.15",
    "typescript": "^5.8.3",
    "vite": "^8.1.3"
